# PostgreSQL — используйте DATABASE_URL (Supabase/Render) ИЛИ отдельные переменные (локально)
# DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require
POSTGRES_USER=funding
POSTGRES_PASSWORD=changeme
POSTGRES_DB=funding
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Telegram
# Токен бота от @BotFather. Без него бот и уведомления отключены.
TELEGRAM_BOT_TOKEN=
# Username бота БЕЗ @ (например funding_alerts_bot). Без него страница
# «Настройки» не может выдать ссылку привязки (ошибка 503 bot not configured).
TELEGRAM_BOT_USERNAME=

# TwelveData Forex API (free plan: 8 req/min — polling every 10s is safe)
TWELVEDATA_API_KEY=

# HTTPS proxy for MOEX ISS (если iss.moex.com недоступен напрямую из Docker)
# Пример: HTTPS_PROXY=http://host.docker.internal:7890
HTTPS_PROXY=

# MOEX polling interval in milliseconds
MOEX_POLL_INTERVAL_MS=250

# Backend HTTP port
BACKEND_PORT=8080

# Log level: debug | info | warn | error
LOG_LEVEL=info
